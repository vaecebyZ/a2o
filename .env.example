A2O_HOST_PORT=11001

# A2O global config (used to generate /tmp/config.json at container startup)
A2O_DEBUG_LEVEL=info
A2O_TIMEOUT_SECONDS=300
A2O_AUTH_TOKEN=my-secret-key

# Single service config
A2O_COMMENT=Compose Service
A2O_LISTEN_ADDRESS=0.0.0.0:11001
A2O_OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
A2O_OPENAI_API_KEY=sk-your-api-key
A2O_FORCE_MODEL=
A2O_UPSTREAM_PROXY=
